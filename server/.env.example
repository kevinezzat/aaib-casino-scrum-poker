# Server environment variables
# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_URI=
PORT=3001

# Allowed CORS origin for the Vite dev client
CLIENT_ORIGIN=http://localhost:5173

# Environment: development | production
NODE_ENV=development

# HTTPS (production only — optional)
# SSL_KEY_PATH=./certs/server.key
# SSL_CERT_PATH=./certs/server.cert
# HTTPS_PORT=3443

# ── Jira OAuth 2.0 (3LO) ──────────────────────────────────────────────────────
# Obtain these from https://developer.atlassian.com/console after creating an
# OAuth 2.0 (3LO) app. See docs/jira-oauth-setup.md for step-by-step instructions.
JIRA_OAUTH_CLIENT_ID=
JIRA_OAUTH_CLIENT_SECRET=
# Must exactly match the Redirect URI registered in the Atlassian developer console.
JIRA_OAUTH_REDIRECT_URI=http://localhost:3001/api/jira/auth/callback
# Space-separated scopes. Defaults to the four required scopes if left blank.
JIRA_OAUTH_SCOPES=read:jira-work write:jira-work offline_access read:jira-user

# ── Token encryption ──────────────────────────────────────────────────────────
# 64-character hex string (32 bytes). Used to encrypt Jira tokens at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ── Jira post-auth redirect ────────────────────────────────────────────────────
# Where to send the browser after OAuth completes (success or failure).
# The callback appends ?jiraConnected=true|false (and ?reason=... on failure).
# Local dev:   http://localhost:5173
# Production:  https://aaib-casino-scrum-poker-client.vercel.app
JIRA_CONNECTED_REDIRECT_URL=http://localhost:5173
